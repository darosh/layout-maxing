{
  "name": "layout-maxing",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint --format=stylish && vp run -r test && vp run -r build",
    "dev": "vp run demo#dev",
    "build": "vp run -r build",
    "build:ghp": "vp run demo#build:ghp",
    "lint": "vp lint --fix"
  },
  "devDependencies": {
    "typescript": "~6.0.0",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "npm@11.12.1"
}
